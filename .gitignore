# Generated public game bundle embedded by the hosted marketing site. Rebuild
# it from the audited public dist instead of versioning a second 60+ MiB copy.
website/public/assets/
website/public/play/

# Local source vault. Public, audited runtime derivatives carry their own
# provenance beside the files that are actually distributed.
assets-source/

# Large local-only SSBU source assets. Keep the catalog and documentation,
# but never add Nintendo archives or extracted game files to Git.
assets-source/archives/
assets-source/extracted/
assets-source/converted/
assets-source/mega-complete/

# Converted Nintendo stage meshes remain part of the private local overlay.
# Open replacements must be audited before any stage asset is versioned.
public/assets/stages/

# Locally supplied/downloaded copyrighted audio masters. Runtime transcodes
# stay in public/assets/audio for this private prototype.
assets-source/downloaded/audio/

# Re-downloadable upstream archives are kept locally for provenance checks.
# Commit manifests, checksums, extracted sources and runtime atlases instead.
assets-source/open-fighters/**/archives/

# Private Smash fighter runtime overlay. These files remain available to the
# local prototype but must never enter the future public repository.
